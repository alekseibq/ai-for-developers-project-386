{
  "name": "calcom-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "pinia": "^3.0",
    "vue": "^3.5",
    "vue-router": "^4.5",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.2",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4",
    "jsdom": "^29.1.1",
    "postcss": "^8.5",
    "tailwindcss": "^3.4",
    "typescript": "^5.7",
    "vite": "^6.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2"
  }
}
