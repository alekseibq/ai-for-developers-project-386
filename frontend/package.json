{
  "name": "calcom-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit && eslint src/",
    "format": "prettier --write src/",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "pinia": "^3.0",
    "vue": "^3.5",
    "vue-router": "^4.5",
    "vue-toastification": "^2.0.0-rc.5"
  },
  "lint-staged": {
    "**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^5.2",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.4",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tailwindcss": "^3.18.3",
    "eslint-plugin-vue": "^10.9.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5",
    "prettier": "^3.8.4",
    "tailwindcss": "^3.4",
    "typescript": "^5.7",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.2",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2"
  }
}
